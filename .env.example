# S.I.R.T. Environment Variables
# Copy this file to .env.local and fill in values as needed.

# Deploy mode: 'vercel' (default, recommended for production) or 'static' (GitHub Pages fallback)
NEXT_PUBLIC_DEPLOY_MODE=vercel

# Vercel serverless only — these NEVER go in the frontend bundle.
# For BYOK (v1), analysts supply their own key in the session UI.
# These are reserved for a future hosted-key model (v3.0).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Claude Code MCP integrations (local dev only)
GITHUB_PERSONAL_ACCESS_TOKEN=
BRAVE_API_KEY=
